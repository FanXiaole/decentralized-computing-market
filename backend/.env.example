# ========== 区块链配置 ==========

# 已部署的合约地址
CONTRACT_ADDRESS_COMPUTE_MARKET=0x...
CONTRACT_ADDRESS_STAKING_MANAGER=0x...
CONTRACT_ADDRESS_REPUTATION_ORACLE=0x...
CONTRACT_ADDRESS_TOKEN=0x...

# Oracle账户私钥（后端用于更新链上信誉分，绝对不要提交到Git！）
ORACLE_PRIVATE_KEY=your_oracle_private_key_here

# RPC URL
RPC_URL=http://127.0.0.1:8545

# ========== 数据库配置 ==========

# SQLite本地文件（开发环境）
DATABASE_URL=sqlite:///./decentai.db

# PostgreSQL（生产环境，Railway/Render提供）
# DATABASE_URL=postgresql://user:password@host/dbname

# ========== 验证器配置 ==========

# 随机抽查比例（每N个任务抽查1个，默认10）
VALIDATION_SAMPLE_RATE=10
