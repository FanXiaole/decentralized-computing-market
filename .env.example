# Sepolia测试网RPC URL（从 Alchemy 或 Infura 获取）
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Polygon主网RPC URL（可选，Gas更便宜）
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# 部署账户私钥（绝对不要提交到Git！）
PRIVATE_KEY=your_private_key_here

# Etherscan API Key（用于合约验证）
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ========== 后端环境变量 ==========

# 已部署的合约地址（运行deploy脚本后填入）
CONTRACT_ADDRESS_COMPUTE_MARKET=
CONTRACT_ADDRESS_STAKING_MANAGER=
CONTRACT_ADDRESS_REPUTATION_ORACLE=
CONTRACT_ADDRESS_TOKEN=

# Oracle账户私钥（后端用于更新链上信誉分）
ORACLE_PRIVATE_KEY=your_oracle_private_key_here

# RPC URL（后端连接区块链使用）
RPC_URL=http://127.0.0.1:8545

# 数据库URL
DATABASE_URL=sqlite:///./decentai.db

# ========== 前端环境变量 ==========

# Vite环境变量（前端使用，前缀必须是VITE_）
VITE_CONTRACT_ADDRESS_COMPUTE_MARKET=
VITE_CONTRACT_ADDRESS_STAKING_MANAGER=
VITE_CONTRACT_ADDRESS_REPUTATION_ORACLE=
VITE_CONTRACT_ADDRESS_TOKEN=
VITE_ALCHEMY_KEY=your_alchemy_key_here
VITE_CHAIN_ID=11155111
